<Window x:Class="Hakamiq.Cso.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Text.WindowTitle, Mode=OneWay, FallbackValue=Hakamiq CsoKit}"
        Icon="Assets/Icons/hakamiq.ico"
        Width="840"
        Height="460"
        MinWidth="800"
        MinHeight="420"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="Segoe UI Variable, Segoe UI"
        FontSize="13"
        FlowDirection="{Binding Text.FlowDirection, Mode=OneWay, FallbackValue=RightToLeft}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1F2023" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#2A2C31" />
        <SolidColorBrush x:Key="SurfaceHoverBrush" Color="#32353B" />
        <SolidColorBrush x:Key="SurfacePressedBrush" Color="#25272C" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#3A3D44" />
        <SolidColorBrush x:Key="BorderBrushStrong" Color="#50545E" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F2F3F5" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B8BCC5" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#8E94A1" />
        <SolidColorBrush x:Key="AccentBrush" Color="#4C9DFF" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#66ADFF" />
        <SolidColorBrush x:Key="AccentPressedBrush" Color="#2F82E6" />
        <SolidColorBrush x:Key="OnAccentBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#4CC38A" />
        <SolidColorBrush x:Key="ErrorBrush" Color="#FF5F57" />
        <SolidColorBrush x:Key="WarningBrush" Color="#F2C94C" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#273B52" />
        <SolidColorBrush x:Key="TaskCardBrush" Color="#303238" />
        <SolidColorBrush x:Key="TaskCardBorderBrush" Color="#424650" />

        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SurfacePressedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Padding" Value="7,3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="Box"
                                    Width="14"
                                    Height="14"
                                    Background="{StaticResource SurfacePressedBrush}"
                                    BorderBrush="{StaticResource BorderBrushStrong}"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    VerticalAlignment="Center">
                                <Path x:Name="Check"
                                      Data="M 3 7 L 6 10 L 11 4"
                                      Stroke="{StaticResource OnAccentBrush}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Visibility="Collapsed" />
                            </Border>

                            <ContentPresenter Grid.Column="1"
                                              Margin="6,0,0,0"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                <Setter Property="Opacity" Value="0.74" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="TaskListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource SurfacePressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="10" />
        </Style>

        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource SurfaceHoverBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource SurfacePressedBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource OnAccentBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource OnAccentBrush}" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentPressedBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentPressedBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource OnAccentBrush}" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.42" />
                                <Setter Property="Foreground" Value="{StaticResource OnAccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OperationRadioStyle" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="ToolTip" Value="{Binding Content, RelativeSource={RelativeSource Self}, Mode=OneWay}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid Width="14"
                                  Height="14"
                                  VerticalAlignment="Center">
                                <Ellipse x:Name="Outer"
                                         Stroke="{StaticResource TextSecondaryBrush}"
                                         StrokeThickness="1.4"
                                         Fill="Transparent" />
                                <Ellipse x:Name="Inner"
                                         Width="7"
                                         Height="7"
                                         Fill="Transparent"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center" />
                            </Grid>

                            <ContentPresenter Grid.Column="1"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Outer" Property="Stroke" Value="{StaticResource BorderBrushStrong}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Outer" Property="Stroke" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Inner" Property="Fill" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Outer" Property="Stroke" Value="{StaticResource TextMutedBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                <Setter Property="Opacity" Value="0.70" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CompactProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="8" />
            <Setter Property="Background" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="Root" ClipToBounds="True">
                            <Border x:Name="PART_Track"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4" />
                            <Decorator x:Name="PART_Indicator"
                                       HorizontalAlignment="Left">
                                <Border Background="{TemplateBinding Foreground}"
                                        CornerRadius="4" />
                            </Decorator>
                            <Border x:Name="IndeterminateIndicator"
                                    Width="96"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="4"
                                    Visibility="Collapsed">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="IndeterminateTranslate" X="-96" />
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsIndeterminate" Value="True">
                                <Setter TargetName="PART_Indicator" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="IndeterminateIndicator" Property="Visibility" Value="Visible" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="IndeterminateProgressStoryboard">
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="IndeterminateTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             From="-96"
                                                             To="360"
                                                             Duration="0:0:1.1">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="IndeterminateProgressStoryboard" />
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10"
          Background="{StaticResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="48" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" MinWidth="330" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" MinWidth="240" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0"
              Grid.ColumnSpan="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="76" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="34" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="1"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0">
                <Run Text="{Binding Text.ProgressSection, Mode=OneWay, FallbackValue=الحالة}" />
                <Run Text=": " />
                <Run Text="{Binding StatusText, Mode=OneWay, FallbackValue=جاهز}" />
            </TextBlock>

            <Button x:Name="LanguageToggleButton"
                    Grid.Column="3"
                    Content="{Binding LanguageToggleText, Mode=OneWay, FallbackValue=English}"
                    Height="28"
                    Padding="8,0"
                    Style="{StaticResource ButtonStyle}"
                    ToolTip="{Binding Text.LanguageToggleToolTip, Mode=OneWay, FallbackValue=Switch language}"
                    IsEnabled="{Binding CanEdit, Mode=OneWay}"
                    Click="LanguageToggleButton_Click" />

            <Button x:Name="GearButton"
                    Grid.Column="5"
                    Width="28"
                    Height="28"
                    Padding="0"
                    Style="{StaticResource ButtonStyle}"
                    ToolTip="{Binding Text.AdvancedOptions, Mode=OneWay, FallbackValue=خيارات متقدمة}"
                    Click="GearButton_Click">
                <TextBlock Text="&#xE713;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="13"
                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Button>
        </Grid>

        <Border x:Name="InputDropZone"
                Grid.Row="1"
                Grid.Column="0"
                Style="{StaticResource PanelStyle}"
                AllowDrop="True"
                DragOver="InputDropZone_DragOver"
                Drop="InputDropZone_Drop">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="78" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="{Binding Text.DropTarget, Mode=OneWay, FallbackValue=اسحب ملفاً أو مجموعة ملفات هنا}"
                               FontSize="15"
                               FontWeight="SemiBold" />

                    <TextBlock Text="ISO / CSO / PSP Folder"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               Margin="0,2,0,8" />

                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BrowseInputButton"
                                Content="{Binding Text.BrowseInput, Mode=OneWay, FallbackValue=اختيار ملفات}"
                                Width="92"
                                Style="{StaticResource ButtonStyle}"
                                IsEnabled="{Binding CanEdit, Mode=OneWay}"
                                Click="BrowseInputButton_Click" />

                        <Button x:Name="BrowseFolderButton"
                                Content="{Binding Text.BrowseFolder, Mode=OneWay, FallbackValue=اختيار مجلد}"
                                Width="92"
                                Margin="8,0,0,0"
                                Style="{StaticResource ButtonStyle}"
                                IsEnabled="{Binding CanEdit, Mode=OneWay}"
                                Click="BrowseFolderButton_Click" />
                    </StackPanel>
                </StackPanel>

                <TextBlock Grid.Row="1"
                           Text="{Binding Text.Tasks, Mode=OneWay, FallbackValue=المهام}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />

                <ListBox Grid.Row="2"
                          ItemsSource="{Binding Tasks, Mode=OneWay}"
                          SelectedItem="{Binding SelectedTask, Mode=TwoWay}"
                          ItemContainerStyle="{StaticResource TaskListBoxItemStyle}"
                          BorderThickness="0"
                          Background="Transparent"
                          HorizontalContentAlignment="Stretch"
                          MouseDoubleClick="TaskListBox_MouseDoubleClick"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8"
                                    Margin="0,0,0,6"
                                     Background="{StaticResource TaskCardBrush}"
                                     BorderBrush="{StaticResource TaskCardBorderBrush}"
                                     BorderThickness="1"
                                     CornerRadius="7">
                                <TextBlock Text="{Binding DisplayName, Mode=OneWay}"
                                           MinHeight="20"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="2"
                Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="{Binding Text.OperationsSection, Mode=OneWay, FallbackValue=نوع العملية}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />

                    <RadioButton Content="{Binding Text.CompactCompress, Mode=OneWay, FallbackValue=ضغط إلى CSO}"
                                 Tag="Compress"
                                 GroupName="Operation"
                                 IsChecked="True"
                                 IsEnabled="{Binding CanEdit, Mode=OneWay}"
                                 Style="{StaticResource OperationRadioStyle}"
                                 Checked="OperationRadioButton_Checked" />

                    <RadioButton Content="{Binding Text.CompactDecompress, Mode=OneWay, FallbackValue=فك إلى ISO}"
                                 Tag="Decompress"
                                 GroupName="Operation"
                                 IsEnabled="{Binding CanEdit, Mode=OneWay}"
                                 Style="{StaticResource OperationRadioStyle}"
                                 Checked="OperationRadioButton_Checked" />

                    <RadioButton Content="{Binding Text.CompactVerify, Mode=OneWay, FallbackValue=فحص}"
                                 Tag="Verify"
                                 GroupName="Operation"
                                 IsEnabled="{Binding CanEdit, Mode=OneWay}"
                                 Style="{StaticResource OperationRadioStyle}"
                                 Checked="OperationRadioButton_Checked" />

                    <RadioButton Content="{Binding Text.CompactRepair, Mode=OneWay, FallbackValue=إصلاح}"
                                 Tag="Repair"
                                 GroupName="Operation"
                                 IsEnabled="{Binding CanEdit, Mode=OneWay}"
                                 Style="{StaticResource OperationRadioStyle}"
                                 Checked="OperationRadioButton_Checked" />
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="{Binding Text.Output, Mode=OneWay, FallbackValue=الإخراج}"
                               FontWeight="SemiBold" />

                    <DockPanel Margin="0,6,0,10">
                        <Button x:Name="ChangeOutputButton"
                                Content="{Binding Text.ChangeOutput, Mode=OneWay, FallbackValue=تغيير}"
                                MinWidth="86"
                                DockPanel.Dock="Right"
                                Style="{StaticResource ButtonStyle}"
                                IsEnabled="{Binding CanBrowseOutput, Mode=OneWay}"
                                Click="BrowseOutputButton_Click" />

                        <TextBlock Text="{Binding CompactOutputText, Mode=OneWay, FallbackValue=تلقائي}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </DockPanel>

                    <TextBlock Text="{Binding CurrentStageText, Mode=OneWay, FallbackValue=جاهز}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis" />

                    <ProgressBar Style="{StaticResource CompactProgressBarStyle}"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding ProgressValue, Mode=OneWay}"
                                 IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}"
                                 Margin="0,6,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2"
              Grid.ColumnSpan="3"
              Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="StartOperationButton"
                    Grid.Column="0"
                    Width="110"
                    Height="34"
                    Style="{StaticResource PrimaryButtonStyle}"
                    IsEnabled="{Binding CanEdit, Mode=OneWay}"
                    Click="StartOperationButton_Click">
                <StackPanel Orientation="Horizontal"
                            FlowDirection="{Binding Text.FlowDirection, Mode=OneWay, FallbackValue=RightToLeft}"
                            HorizontalAlignment="Center">
                    <TextBlock Text="▶"
                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <TextBlock Text="{Binding Text.StartOperation, Mode=OneWay, FallbackValue=بدء}"
                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button x:Name="StopOperationButton"
                    Grid.Column="1"
                    Content="{Binding Text.StopOperation, Mode=OneWay, FallbackValue=إيقاف}"
                    Width="82"
                    Height="34"
                    Margin="8,0,0,0"
                    Style="{StaticResource ButtonStyle}"
                    IsEnabled="False" />

            <Button x:Name="ClearLogButton"
                    Grid.Column="2"
                    Content="{Binding Text.ClearLog, Mode=OneWay, FallbackValue=مسح}"
                    Width="82"
                    Height="34"
                    Margin="8,0,0,0"
                    Style="{StaticResource ButtonStyle}"
                    Click="ClearLogButton_Click" />

            <Button x:Name="OpenOutputButton"
                    Grid.Column="4"
                    Content="{Binding OpenResultText, Mode=OneWay, FallbackValue=فتح التقرير}"
                    Width="96"
                    Height="34"
                    Style="{StaticResource ButtonStyle}"
                    IsEnabled="{Binding CanOpenOutput, Mode=OneWay}"
                    Click="OpenOutputButton_Click" />
        </Grid>

        <Popup IsOpen="{Binding IsAdvancedOptionsOpen, Mode=TwoWay}"
               DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
               PlacementTarget="{Binding ElementName=GearButton}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True">
            <Border Width="260"
                    MaxHeight="260"
                    Padding="12"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushStrong}"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="{Binding Text.AdvancedOptions, Mode=OneWay, FallbackValue=خيارات متقدمة}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4" />

                    <TextBlock Text="{Binding Text.KeepDefaultsHint, Mode=OneWay, FallbackValue=اتركها كما هي لأفضل توافق.}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10" />

                     <CheckBox Content="{Binding Text.DeepVerify, Mode=OneWay, FallbackValue=فحص عميق}"
                               IsChecked="{Binding DeepVerify, Mode=TwoWay}"
                               IsEnabled="{Binding CanUseDeepVerify, Mode=OneWay}"
                               ToolTip="{Binding Text.DeepVerifyToolTip, Mode=OneWay, FallbackValue=يزيد دقة الفحص وقد يستغرق وقتاً أطول.}"
                               ToolTipService.ShowOnDisabled="True"
                               Margin="0,0,0,6" />

                     <CheckBox Content="{Binding Text.Sha256, Mode=OneWay, FallbackValue=SHA256}"
                               IsChecked="{Binding ComputeSha256, Mode=TwoWay}"
                               IsEnabled="{Binding CanUseSha256, Mode=OneWay}"
                               ToolTip="{Binding Text.Sha256ToolTip, Mode=OneWay, FallbackValue=يحسب بصمة الملف للتحقق أو المقارنة.}"
                               ToolTipService.ShowOnDisabled="True"
                               Margin="0,0,0,6" />

                     <CheckBox Content="{Binding Text.CodecReport, Mode=OneWay, FallbackValue=تقرير الضغط}"
                               IsChecked="{Binding CollectCodecReport, Mode=TwoWay}"
                               IsEnabled="{Binding CanUseCodecReport, Mode=OneWay}"
                               ToolTip="{Binding Text.CodecReportToolTip, Mode=OneWay, FallbackValue=يعرض ملخصاً تقنياً مختصراً بعد العملية.}"
                               ToolTipService.ShowOnDisabled="True"
                               Margin="0,0,0,6" />

                     <CheckBox Content="{Binding Text.ForceOverwrite, Mode=OneWay, FallbackValue=استبدال الموجود}"
                               IsChecked="{Binding ForceOverwrite, Mode=TwoWay}"
                               IsEnabled="{Binding CanUseForceOverwrite, Mode=OneWay}"
                               ToolTip="{Binding Text.ForceOverwriteToolTip, Mode=OneWay, FallbackValue=يسمح بالكتابة فوق ملف الناتج إذا كان موجوداً.}"
                               ToolTipService.ShowOnDisabled="True"
                               Margin="0,0,0,10" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Text.Threads, Mode=OneWay, FallbackValue=العمليات المتزامنة}"
                                       FontSize="11" />

                            <TextBox Text="1"
                                     Height="26"
                                     IsEnabled="False"
                                     ToolTip="{Binding Text.ThreadsToolTip, Mode=OneWay, FallbackValue=عدد الملفات أو العمليات التي يمكن تشغيلها في نفس الوقت. اتركها 1 لأفضل استقرار.}"
                                     ToolTipService.ShowOnDisabled="True"
                                     Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{Binding Text.BlockSize, Mode=OneWay, FallbackValue=حجم الكتلة}"
                                       FontSize="11" />

                             <TextBox Text="{Binding BlockSizeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Height="26"
                                      IsEnabled="{Binding CanUseBlockSize, Mode=OneWay}"
                                      ToolTip="{Binding Text.BlockSizeToolTip, Mode=OneWay, FallbackValue=حجم كتلة CSO؛ اتركه كما هو غالباً.}"
                                      ToolTipService.ShowOnDisabled="True"
                                      Margin="0,4,0,0" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
